
# DATABASE (Neon PostgreSQL with connection pooling)

DATABASE_URL=postgresql://user:password@ep-xxx-xxx-123456.us-east-2.aws.neon.tech/neondb?sslmode=require


# BETTER AUTH (Self-Hosted Authentication)

BETTER_AUTH_SECRET=your_32_plus_character_random_secret_here
BETTER_AUTH_API_KEY=ba_your_api_key_here
# =============================================================================
# RENDER DEPLOYMENT
# =============================================================================
# Backend URL (this is the backend itself)
BETTER_AUTH_URL=https://l-spa-backend.onrender.com

# Trusted origins - Frontend Vercel URLs (including preview deployments)
BETTER_AUTH_TRUSTED_ORIGINS=https://l-spa.vercel.app,https://l-spa-git-*.vercel.app,http://localhost:5173,http://localhost:5174


# SENTRY ERROR TRACKING (Optional)

SENTRY_DSN=https://xxxxxx@o1234567.ingest.sentry.io/1234567


# ENVIRONMENT

NODE_ENV=production
