# =============================================================================
# BACKEND (Vercel Project) - SERVER-ONLY VARIABLES
# =============================================================================

# Runtime
NODE_ENV=production
PORT=3000

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@ep-xxx-xxx-123456.us-east-2.aws.neon.tech/neondb?sslmode=require

# Better Auth
BETTER_AUTH_SECRET=your_32_plus_character_random_secret_here
BETTER_AUTH_API_KEY=ba_your_api_key_here

# Backend canonical URL (no trailing slash)
BETTER_AUTH_URL=https://l-spa-backend.vercel.app/api/v1/auth

# Comma-separated frontend origins allowed for auth + CORS (no trailing slash)
BETTER_AUTH_TRUSTED_ORIGINS=https://l-spa.vercel.app,https://l-spa-frontend.vercel.app,https://l-spa-git-*.vercel.app,http://localhost:5173,http://localhost:5174

# Monitoring (optional)
SENTRY_DSN=https://xxxxxx@o1234567.ingest.sentry.io/1234567

# Rate Limiting (optional - defaults to 5 attempts / 15 minutes)
RATE_LIMIT_MAX_ATTEMPTS=5
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_LOCKOUT_DURATION_MS=900000
