{
	"extends": "./.svelte-kit/tsconfig.json",
	"compilerOptions": {
		"skipLibCheck": true,
		"moduleResolution": "bundler",
		"module": "esnext",
		"lib": ["esnext", "dom", "dom.iterable"],
		"types": ["@sveltejs/kit", "vite"]
	},
	"include": [
		"src/**/*.ts",
		"src/**/*.svelte",
		".svelte-kit/types/**/*.d.ts"
	]
}
