# =============================================================================
# AUTH0 AUTHENTICATION (only needed if migrating back from better-auth)
# =============================================================================
# AUTH0_DOMAIN=your-tenant.auth0.com
# AUTH0_CLIENT_ID=abc123...
# AUTH0_CLIENT_SECRET=secret...
# AUTH0_CALLBACK_URL=https://l-spa.com/callback
# AUTH0_BASE_URL=https://l-spa.com
# AUTH0_AUDIENCE=https://api.l-spa.com

# =============================================================================
# BETTER AUTH (Primary Auth Method)
# =============================================================================
BETTER_AUTH_SECRET=base64:YOUR_32_BYTE_SECRET_HERE
BETTER_AUTH_URL=https://api.l-spa.com/api/v1/auth

# =============================================================================
# DATABASE (Neon PostgreSQL with connection pooling)
# =============================================================================
DATABASE_URL=postgresql://user:password@ep-xxx-xxx-123456.us-east-2.aws.neon.tech/neondb?sslmode=require&pgbouncer=true

# =============================================================================
# SENTRY ERROR TRACKING
# =============================================================================
# Server-side (not exposed to client)
SENTRY_DSN=https://xxxxxx@o1234567.ingest.sentry.io/1234567

# Client-side (VITE_ prefix exposes to client)
VITE_SENTRY_DSN=https://xxxxxx@o1234567.ingest.sentry.io/1234567

# =============================================================================
# VERCEL DEPLOYMENT
# =============================================================================
# Backend API URL (Render backend)
PUBLIC_API_URL=https://l-spa-backend.onrender.com/api/v1

# Frontend URL (Vercel)
PUBLIC_SITE_URL=https://l-spa.vercel.app

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=info
