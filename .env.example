# Root .env is for local monorepo convenience only.
# For deployment, configure each Vercel project separately:
# - Frontend vars: apps/frontend/.env.example
# - Backend vars: apps/backend/.env.example

# Optional local defaults
PUBLIC_API_URL=http://localhost:3000/api/v1
PUBLIC_SITE_URL=http://localhost:5173
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:5173,http://localhost:5174
LOG_LEVEL=info
