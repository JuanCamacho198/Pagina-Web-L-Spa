{
  "name": "l-spa",
  "version": "0.0.0",
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@l-spa/shared-types": "workspace:*",
    "bun-types": "^1.1.0",
    "concurrently": "^7.6.0",
    "eslint": "^9.0.0",
    "eslint-plugin-svelte": "^2.4.0",
    "svelte-eslint-parser": "^0.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.0.0",
    "vite": "^7.0.0",
    "vitest": "^3.0.0"
  },
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n backend,frontend -c yellow,cyan \"bun --hot apps/backend/src/index.ts\" \"cd apps/frontend && bun run dev\"",
    "dev:backend:root": "bun --hot apps/backend/src/index.ts",
    "build": "bun run --filter \"*\" build",
    "typecheck": "tsc --noEmit",
    "lint": "bun run --filter \"*\" lint",
    "db:push": "bun run --filter @l-spa/database db:push",
    "db:studio": "bun run --filter @l-spa/database db:studio",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:run": "vitest run",
    "test:e2e": "echo 'Use Playwright MCP for E2E tests'",
    "test:all": "bun test:run && bun test:e2e",
    "release": "semantic-release",
    "release:dry": "semantic-release --dry-run",
    "prepare": "husky install"
  },
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@sveltejs/enhanced-img": "^0.10.4"
  }
}
