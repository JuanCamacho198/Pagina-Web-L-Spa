{
  "name": "l-spa",
  "version": "0.0.0",
  "devDependencies": {
    "@l-spa/shared-types": "workspace:*",
    "typescript": "^5.9.3"
  },
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "bun run --filter \"*\" dev",
    "build": "bun run --filter \"*\" build",
    "lint": "bun run --filter \"*\" lint",
    "db:push": "bun run --filter @l-spa/database db:push",
    "db:studio": "bun run --filter @l-spa/database db:studio"
  },
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
