{
  "version": 2,
  "builds": [
    {
      "src": "apps/backend/src/vercel.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "packages/database/**",
          "packages/shared-types/**",
          "apps/backend/src/**"
        ]
      }
    },
    {
      "src": "apps/frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": ".svelte-kit/vercel"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/v1/(.*)",
      "dest": "apps/backend/src/vercel.ts"
    },
    {
      "src": "/(.*)",
      "dest": "apps/frontend/$1"
    }
  ]
}