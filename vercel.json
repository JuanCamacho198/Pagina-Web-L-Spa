{
  "version": 2,
  "builds": [
    {
      "src": "apps/backend/src/vercel.ts",
      "use": "@vercel/node",
      "config": {
        "runtime": "nodejs24.x"
      }
    },
    {
      "src": "apps/frontend/package.json",
      "use": "@sveltejs/vercel"
    }
  ],
  "routes": [
    {
      "src": "/api/v1/(.*)",
      "dest": "apps/backend/src/vercel.ts"
    }
  ]
}
