{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "types": ["bun-types"],
    "baseUrl": ".",
    "paths": {
      "@l-spa/database": ["./packages/database/src/index.ts"],
      "@l-spa/shared-types": ["./packages/shared-types/src/index.ts"]
    }
  },
  "exclude": ["node_modules"]
}
